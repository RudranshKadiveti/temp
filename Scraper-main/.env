# Universal Extraction Engine Configuration
# ============================================

# ============================================
# LLM & AI Configuration (OpenRouter)
# ============================================

# OpenRouter API Key (Primary LLM Provider for structuring)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# OpenRouter Model for LLM structuring & fallback
# Recommended models:
#   - openai/gpt-3.5-turbo (fast, cheap, good for structuring)
#   - openai/gpt-4 (slower, expensive, better quality)
#   - anthropic/claude-2 (good reasoning)
#   - mistral/mistral-7b (free/cheap)
#   - meta-llama/llama-2 (open source)
OPENROUTER_MODEL=mistral/mistral-7b

# Groq API Key (Optional - Fast inference for product name/brand structuring)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq Model for fast product structuring
GROQ_MODEL=mixtral-8x7b-32768

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# PostgreSQL Connection String (full URL - preferred)
# Format: postgresql+asyncpg://user:password@host:port/database
POSTGRES_URL=postgresql+asyncpg://scraper:scraper_password@localhost:5432/scraper_db

# OR use individual components (used if POSTGRES_URL not set)
POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=scraper_db

# ============================================
# Redis Configuration
# ============================================

# Redis Connection URL
REDIS_URL=redis://localhost:6379/0

# Redis Settings (used if REDIS_URL not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# Elasticsearch Configuration
# ============================================

# Elasticsearch Connection URL
ELASTICSEARCH_URL=http://localhost:9200

# Elasticsearch Settings (used if URL not set)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

# ============================================
# Scraper Configuration
# ============================================

# Default output format (csv, json, jsonl, xlsx, parquet)
DEFAULT_OUTPUT_FORMAT=csv

# HTML Storage Path
HTML_STORAGE_PATH=./data/raw_html

# Output Storage Path
OUTPUT_STORAGE_PATH=./data/output

# Maximum concurrent requests
CONCURRENCY=100

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# ============================================
# Data Pipeline & Processing
# ============================================

# Enable schema inference
ENABLE_SCHEMA_INFERENCE=true

# Enable data validation
ENABLE_DATA_VALIDATION=true

# Enable deduplication (removes duplicate products)
ENABLE_DEDUPLICATION=true

# Deduplication hash fields (comma-separated)
DEDUP_FIELDS=name,brand,url

# ============================================
# Anti-Bot & Browser Settings
# ============================================

# Browser headless mode (true/false)
HEADLESS_BROWSER=true

# Enable JavaScript rendering (Playwright for SPAs)
JS_RENDERING_ENABLED=true

# User Agent rotation
USER_AGENT_ROTATION=true

# Request delay (milliseconds between requests)
REQUEST_DELAY=500

# Random delay range (min-max milliseconds)
RANDOM_DELAY_MIN=200
RANDOM_DELAY_MAX=1500

# ============================================
# LLM Structuring Configuration
# ============================================

# Enable LLM-based content extraction (fallback layer 3)
ENABLE_LLM_FALLBACK=true

# Enable product name/brand structuring with LLM
ENABLE_LLM_STRUCTURING=true

# LLM Structuring Timeout (seconds)
LLM_TIMEOUT=30

# LLM Max tokens for responses
LLM_MAX_TOKENS=500

# LLM Temperature (0.0-2.0, lower = more deterministic, higher = more creative)
LLM_TEMPERATURE=0.3

# ============================================
# Logging Configuration
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs.txt

# Log to console
LOG_TO_CONSOLE=true

# ============================================
# API Server Configuration
# ============================================

# API Server Host (0.0.0.0 = accessible from outside)
API_HOST=0.0.0.0

# API Server Port
API_PORT=8000

# Enable CORS
CORS_ENABLED=true

# CORS Origins (comma-separated, use * for all)
CORS_ORIGINS=*

# ============================================
# Feature Toggles
# ============================================

# Enable API discovery (find hidden JSON APIs)
ENABLE_API_DISCOVERY=true

# Enable debug snapshots (saves HTML/screenshots on failure)
DEBUG_SNAPSHOTS=false

# ============================================
# Environment
# ============================================

# Node environment (development, production)
NODE_ENV=development

# Debug mode (verbose logging)
DEBUG=false
